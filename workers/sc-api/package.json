{
  "name": "sc-api",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --local --port 8787",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute sc-db --remote --file=migrations/0001_initial_schema.sql",
    "db:migrate:local": "wrangler d1 execute sc-db --local --file=migrations/0001_initial_schema.sql",
    "db:seed": "wrangler d1 execute sc-db --remote --file=migrations/seed.sql",
    "db:seed:local": "wrangler d1 execute sc-db --local --file=migrations/seed.sql",
    "db:reset:local": "wrangler d1 execute sc-db --local --file=migrations/0001_initial_schema.sql && wrangler d1 execute sc-db --local --file=migrations/seed.sql",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.12.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240129.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.69.0"
  }
}
