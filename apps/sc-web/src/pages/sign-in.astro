---
import Base from '../layouts/Base.astro';
import { SignIn as ClerkSignIn } from '@clerk/astro/components';
---

<Base
  title="Sign in | Silicon Crane"
  description="Sign in to access the Silicon Crane validation tooling."
>
  <main class="min-h-screen bg-slate-50 flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-sm">
      <div class="text-center mb-6">
        <h1 class="text-2xl font-bold text-slate-900">Silicon Crane</h1>
        <p class="text-sm text-slate-600 mt-1">Sign in to the validation tooling</p>
      </div>
      <div class="flex justify-center">
        <ClerkSignIn signUpUrl="/sign-in" forceRedirectUrl="/app" />
      </div>
    </div>
  </main>
</Base>
